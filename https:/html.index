<!DOCTYPE html>
<html lang="tr">

<head>

<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">

<title>Sinan'ın Spor Blogu</title>

<style>

/* GENEL */

:root{
--bg:#111;
--card:#1e1e1e;
--accent:#ff9800;
--accent2:#ffb74d;
--text:#fff;
}

body{
margin:0;
font-family:Arial, Helvetica, sans-serif;
background:var(--bg);
color:var(--text);
line-height:1.6;
}

/* GECE MODU */

.light{
--bg:#f4f4f4;
--card:#ffffff;
--text:#111;
}

/* ÜST BAR */

.topbar{
display:flex;
justify-content:space-between;
padding:12px 25px;
background:#000;
font-size:15px;
align-items:center;
flex-wrap:wrap;
}

.topbar button{
padding:6px 14px;
border:none;
border-radius:6px;
cursor:pointer;
background:var(--accent);
color:#fff;
}

/* HERO */

.hero{
height:250px;
background:#222;
display:flex;
align-items:center;
justify-content:center;
text-align:center;
}

.hero h1{
font-size:34px;
background:rgba(0,0,0,0.6);
padding:20px;
border-radius:10px;
}

/* LAYOUT */

.container{
display:flex;
flex-wrap:wrap;
gap:25px;
padding:40px;
}

.blog{
flex:3;
min-width:280px;
}

.sidebar{
flex:1;
background:var(--card);
padding:20px;
border-radius:10px;
}

/* BUTON */

.button{
background:var(--accent);
padding:12px 25px;
border:none;
border-radius:8px;
cursor:pointer;
margin-top:15px;
font-weight:bold;
transition:0.3s;
}

.button:hover{
background:var(--accent2);
transform:scale(1.05);
}

/* PLAN */

.plan{
display:none;
background:var(--card);
padding:20px;
margin-top:20px;
border-radius:10px;
}

/* MOTIVASYON */

.motivation{
font-size:20px;
font-style:italic;
margin-bottom:20px;
}

/* FİLMLER */

.movies{
display:grid;
grid-template-columns:repeat(auto-fit,minmax(220px,1fr));
gap:20px;
padding:40px;
}

.movie{
background:var(--card);
border-radius:10px;
padding:15px;
text-align:center;
transition:0.3s;
}

.movie:hover{
transform:translateY(-5px);
}

/* ARAÇLAR */

.tools{
text-align:center;
padding:60px 20px;
}

input, textarea{
padding:10px;
border-radius:6px;
border:none;
margin:8px;
width:220px;
}

/* YORUM */

.comment{
background:var(--card);
padding:15px;
margin:10px auto;
max-width:500px;
border-radius:8px;
text-align:left;
}

/* FOOTER */

footer{
text-align:center;
padding:30px;
background:#000;
margin-top:40px;
font-size:14px;
}

</style>

</head>

<body>

<!-- ÜST BAR -->

<div class="topbar">

<span>🕒 <span id="clock"></span></span>

<span>👥 Ziyaretçi: <span id="visitorCount">130</span></span>

<button onclick="toggleMode()">🌙 Mod</button>

</div>

<!-- HERO -->

<section class="hero">

<h1>Sinan'ın Spor Antrenman Blogu</h1>

</section>

<!-- BLOG -->

<div class="container">

<div class="blog">

<h2>Motivasyon</h2>

<p class="motivation">
"Disiplin güçlü bir vücut ve güçlü bir karakterin temelidir."
</p>

<p>Bu blogda kendi fitness antrenman planımı paylaşıyorum.</p>

<button class="button" onclick="showPlan()">Antrenman Planını Aç</button>

<div id="plan" class="plan">

<h2>Sinan'ın Fitness Programı</h2>

<button class="button" onclick="copyPlan()">Planı Kopyala</button>

<div id="planText">

<h3>1.Gün – Sırt & Biceps</h3>

<ul>
<li>Lat Pulldown – 5x8</li>
<li>Seated Row – 4x10</li>
<li>Biceps Curl – 4x12</li>
</ul>

<h3>2.Gün – Göğüs & Arka Kol</h3>

<ul>
<li>Bench Press – 5x8</li>
<li>Cable Crossover – 4x12</li>
<li>Triceps Pushdown – 4x12</li>
</ul>

<h3>3.Gün – Omuz</h3>

<ul>
<li>Shoulder Press – 5x8</li>
<li>Lateral Raise – 4x12</li>
<li>Face Pull – 3x15</li>
</ul>

</div>
</div>

</div>

<div class="sidebar">

<h3>Günün Sözü</h3>

<p>"Allah sabredenlerle beraberdir."</p>

</div>

</div>

<!-- FİLMLER -->

<section>

<h2 style="text-align:center">Sevdiğim Filmler</h2>

<div class="movies">

<div class="movie">
<h3>Close Range</h3>
<p>Aksiyon filmi</p>
</div>

<div class="movie">
<h3>Avengement</h3>
<p>İntikam temalı aksiyon</p>
</div>

<div class="movie">
<h3>Rambo</h3>
<p>Klasik aksiyon filmi</p>
</div>

</div>

</section>

<!-- BMI -->

<section class="tools">

<h2>BMI Hesaplama</h2>

<input id="kilo" placeholder="Kilo (kg)">
<input id="boy" placeholder="Boy (cm)">

<br>

<button class="button" onclick="bmi()">Hesapla</button>

<p id="bmiSonuc"></p>

</section>

<!-- YORUM -->

<section class="tools">

<h2>Ziyaretçi Yorumları</h2>

<input id="isim" placeholder="Adınız">

<br>

<textarea id="yorum" placeholder="Yorum yaz"></textarea>

<br>

<button class="button" onclick="yorumEkle()">Yorum Gönder</button>

<div id="yorumlar"></div>

</section>

<footer>

© 2026 Sinan Fitness Blog

</footer>

<script>

/* PLAN AÇ */

function showPlan(){

let plan=document.getElementById("plan");

plan.style.display=(plan.style.display==="block")?"none":"block";

}

/* PLAN KOPYALA */

function copyPlan(){

let text=document.getElementById("planText").innerText;

navigator.clipboard.writeText(text);

alert("Antrenman planı kopyalandı 💪");

}

/* SAAT */

setInterval(()=>{

document.getElementById("clock").innerHTML=
new Date().toLocaleTimeString("tr-TR");

},1000);

/* ZİYARETÇİ */

let count=localStorage.getItem("visitor");

if(!count){
count=130;
}else{
count=parseInt(count)+1;
}

localStorage.setItem("visitor",count);

document.getElementById("visitorCount").innerText=count;

/* MOD */

function toggleMode(){

document.body.classList.toggle("light");

}

/* BMI */

function bmi(){

let kilo=document.getElementById("kilo").value;

let boy=document.getElementById("boy").value/100;

let sonuc=kilo/(boy*boy);

document.getElementById("bmiSonuc").innerText="BMI: "+sonuc.toFixed(2);

}

/* YORUM */

function yorumEkle(){

let isim=document.getElementById("isim").value;

let yorum=document.getElementById("yorum").value;

if(isim=="" || yorum==""){
alert("Yorum yazınız");
return;
}

let div=document.createElement("div");

div.className="comment";

div.innerHTML="<b>"+isim+"</b><br>"+yorum;

document.getElementById("yorumlar").prepend(div);

}

</script>

</body>
</html>
